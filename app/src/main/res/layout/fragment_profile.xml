<?xml version="1.0" encoding="utf-8"?>
<!-- PROFILE / USER FRAGMENT — Retro 8-bit Brutalist -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <include layout="@layout/layout_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="130dp">



        <!-- === AVATAR + USER INFO === -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <!-- Avatar square -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@color/card_header">

                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="P"
                    android:textColor="@color/card_header_text"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivAvatarDisplay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"/>
            </FrameLayout>

            <!-- Name -->
            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:letterSpacing="0.02"
                android:text="PLANIFY_USER"
                android:textAllCaps="true"
                android:textColor="@color/on_surface"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Email -->
            <TextView
                android:id="@+id/tvUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="user@planify.sys"
                android:textColor="@color/on_surface_muted"
                android:textSize="13sp" />

            <!-- Edit Profile link -->
            <TextView
                android:id="@+id/tvEditProfile"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_brutalist_card"
                android:letterSpacing="0.05"
                android:paddingHorizontal="8dp"
                android:paddingVertical="8dp"
                android:text="EDIT_PROFILE"
                android:textAllCaps="true"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- === STATS SECTION === -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:orientation="vertical"
            android:background="@drawable/bg_brutalist_card">

            <!-- Stats Header (inverted) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/card_header"
                android:padding="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MISSION_STATS"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/card_header_text"
                    android:letterSpacing="0.05"
                    android:textAllCaps="true"/>

            </LinearLayout>

            <!-- Stats Grid 2x2 -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:background="@color/card_header">

                <!-- Total Tasks -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:background="@color/surface"
                    android:layout_margin="1dp">

                    <TextView
                        android:id="@+id/tvTotalTasks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL_TASKS"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface_muted"
                        android:letterSpacing="0.05"
                        android:textAllCaps="true"/>

                </LinearLayout>

                <!-- Completed -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:background="@color/surface"
                    android:layout_margin="1dp">

                    <TextView
                        android:id="@+id/tvCompletedTasks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="COMPLETED"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface_muted"
                        android:letterSpacing="0.05"
                        android:textAllCaps="true"/>

                </LinearLayout>

                <!-- Pomodoros -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:background="@color/surface"
                    android:layout_margin="1dp">

                    <TextView
                        android:id="@+id/tvTotalPomodoros"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="POMODOROS"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface_muted"
                        android:letterSpacing="0.05"
                        android:textAllCaps="true"/>

                </LinearLayout>

                <!-- Completion Rate -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:background="@color/surface"
                    android:layout_margin="1dp">

                    <TextView
                        android:id="@+id/tvCompletionRate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EFFICIENCY"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface_muted"
                        android:letterSpacing="0.05"
                        android:textAllCaps="true"/>

                </LinearLayout>

            </GridLayout>

            <!-- Mission Log Button -->
            <TextView
                android:id="@+id/btnViewMissionLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/card_header"
                android:padding="12dp"
                android:text="[ OPEN_MISSION_LOG ]"
                android:textColor="@color/card_header_text"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />

        </LinearLayout>

        <!-- === STREAK CARD === -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="@drawable/bg_brutalist_card">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/card_header"
                android:padding="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CURRENT_STREAK"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/card_header_text"
                    android:letterSpacing="0.05"
                    android:textAllCaps="true"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⊙"
                    android:textSize="12sp"
                    android:textColor="@color/card_header_text"/>

            </LinearLayout>

            <!-- Body -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 DAYS"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:letterSpacing="-0.01"/>

            </LinearLayout>

        </LinearLayout>

        <!-- === SYSTEM PREFERENCES === -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="@drawable/bg_brutalist_card">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/card_header"
                android:padding="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SYSTEM_PREFERENCES"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/card_header_text"
                    android:letterSpacing="0.05"
                    android:textAllCaps="true"/>

            </LinearLayout>

            <!-- Settings Button -->
            <LinearLayout
                android:id="@+id/btnOpenSettings"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@color/surface"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⊡ Settings"
                    android:textSize="15sp"
                    android:textColor="@color/on_surface"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_muted"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Spacer -->
        <View android:layout_width="match_parent" android:layout_height="16dp"/>

        <!-- === TERMINATE SESSION BUTTON === -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:orientation="vertical">

            <!-- Primary sign-out: red inverted -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignOut"
                style="@style/Widget.Planify.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:letterSpacing="0.05"
                android:text="⊗  TERMINATE_SESSION"
                android:textAllCaps="true"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@color/error_color" />

        </LinearLayout>

    </LinearLayout>

    </ScrollView>
</LinearLayout>
