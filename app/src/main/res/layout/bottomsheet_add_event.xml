<?xml version="1.0" encoding="utf-8"?>
<!-- ADD/EDIT EVENT BOTTOM SHEET — Retro 8-bit Brutalist (matches Add Task UI) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_retro_bottomsheet">

    <!-- Inverted header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_header"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvSheetTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+ NEW_EVENT"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/card_header_text"
            android:letterSpacing="0.05"
            android:textAllCaps="true"/>

        <View
            android:id="@+id/headerAccent"
            android:layout_width="32dp"
            android:layout_height="4dp"
            android:background="@color/background"/>

    </LinearLayout>

    <!-- Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="48dp">

        <!-- Event Title Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_brutalist_card">
            <EditText
                android:id="@+id/etEventTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:padding="16dp"
                android:textColor="@color/on_surface"
                android:hint="EVENT_TITLE"
                android:textColorHint="@color/on_surface_muted"
                android:textSize="14sp"
                android:textStyle="bold"
                android:imeOptions="actionNext"
                android:inputType="textCapSentences"/>
        </LinearLayout>

        <!-- Description Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_brutalist_card">
            <EditText
                android:id="@+id/etEventDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:padding="16dp"
                android:textColor="@color/on_surface"
                android:hint="DESCRIPTION (OPTIONAL)"
                android:textColorHint="@color/on_surface_muted"
                android:textSize="14sp"
                android:textStyle="bold"
                android:minLines="2"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"/>
        </LinearLayout>

        <!-- Event Date Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSetDate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="⊡  SET_DATE"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            style="@style/Widget.Planify.Button.Outlined"
            app:icon="@drawable/ic_calendar"
            app:iconTint="@color/on_surface"/>

        <!-- Start Time Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartTime"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="🕒  START_TIME"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            style="@style/Widget.Planify.Button.Outlined"/>

        <!-- End Time Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEndTime"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="🕒  END_TIME"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            style="@style/Widget.Planify.Button.Outlined"/>

        <!-- Separator -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/card_header"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"/>

        <!-- Create/Save Event button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateEvent"
            style="@style/Widget.Planify.Button"
            android:layout_width="match_parent"
            android:layout_height="69dp"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.05"
            android:text="+ CREATE_EVENT"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Delete Event button (hidden by default, shown in edit mode) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteEvent"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="✖ DELETE EVENT"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/priority_high"
            android:visibility="gone"
            style="@style/Widget.Planify.Button.Outlined"
            app:strokeColor="@color/priority_high"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
