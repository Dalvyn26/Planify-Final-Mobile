<?xml version="1.0" encoding="utf-8"?>
<!-- MISSION LOG ACTIVITY — Retro 8-bit Brutalist -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Custom App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/card_header"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="?attr/actionBarSize"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:tint="@color/accent_on"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=">_ MISSION_LOG"
            android:textColor="@color/card_header_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@color/surface" />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/card_header" />

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Title Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/card_header"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ARCHIVED_MISSIONS"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/card_header_text"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/tvLogCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 RECORDS"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:background="@color/surface"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:letterSpacing="0.05"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMissionLog"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="16dp"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_brutalist_container"/>

        </LinearLayout>

        <!-- Empty state text -->
        <TextView
            android:id="@+id/tvEmptyLog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="> NO_ARCHIVED_MISSIONS\n  RECORDS_ARE_EMPTY."
            android:textColor="@color/on_surface_muted"
            android:gravity="center"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:visibility="gone"/>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</LinearLayout>
