<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/card_header"
    android:orientation="vertical"
    android:paddingTop="40dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <!-- Logo with contrasting background -->
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/terminal"
            android:background="@color/surface"
            android:padding="4dp"
            android:layout_marginEnd="8dp"
            app:tint="@color/on_surface"
            android:contentDescription="Terminal Logo"/>

        <!-- Title in light color -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PLANIFY"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/card_header_text"
            android:letterSpacing="0.05"
            android:textAllCaps="true"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/background"/>

</LinearLayout>
