<?xml version="1.0" encoding="utf-8"?>
<!-- HOME FRAGMENT — Retro 8-bit Brutalist / DASH screen -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <include layout="@layout/layout_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="130dp">

            <!-- === GREETING / LEVEL CARD === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:padding="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_brutalist_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvGreetingName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LEVEL 1"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/tvDashboardUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COMMANDER"
                            android:textSize="22sp"
                            android:textStyle="normal"
                            android:textColor="@color/on_surface_secondary"
                            android:letterSpacing="0.05"/>
                    </LinearLayout>
                    
                    <TextView
                        android:id="@+id/tvXpProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="XP: 0 / 1000"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:gravity="end"
                        android:layout_gravity="top"/>
                </LinearLayout>

                <!-- XP Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_border_only"
                    android:padding="2dp"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="4dp"
                    android:weightSum="1000">
                    <View
                        android:id="@+id/viewXpFill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0"
                        android:background="@color/accent"/>
                    <View
                        android:id="@+id/viewXpEmpty"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1000"
                        android:background="@android:color/transparent"/>
                </LinearLayout>

            </LinearLayout>

            <!-- === WEATHER + MINI CALENDAR CARD === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_brutalist_container">

                <!-- WEATHER SECTION -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- City Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="● "
                            android:textSize="14sp"
                            android:textColor="@color/on_surface"/>
                        <TextView
                            android:id="@+id/tvCityName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CITY_NODE: MAKASSAR"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface"
                            android:letterSpacing="0.05"/>

                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                        <ImageButton
                            android:id="@+id/btnRefreshWeather"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@null"
                            android:src="@drawable/ic_refresh"
                            android:contentDescription="Refresh weather"
                            android:padding="0dp"
                            app:tint="@color/on_surface"/>
                    </LinearLayout>

                    <!-- Weather Info Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:paddingBottom="12dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/ivWeatherIcon"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_weather_clear"
                            android:contentDescription="Weather icon"
                            app:tint="@color/on_surface"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:id="@+id/tvTemperature"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TEMP: 28°C"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface"
                                android:letterSpacing="0.05"/>
                            <TextView
                                android:id="@+id/tvWeatherDesc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="COND: CLEAR_SKIES"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface_secondary"
                                android:letterSpacing="0.05"
                                android:textAllCaps="true"/>
                        </LinearLayout>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressWeather"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:visibility="gone"
                        android:indeterminateTint="@color/accent"
                        style="?android:attr/progressBarStyleHorizontal"/>

                    <TextView
                        android:id="@+id/tvWeatherError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="NO INTERNET CONNECTION"
                        android:textColor="@color/on_surface_muted"
                        android:gravity="center"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"
                        android:visibility="gone"
                        android:padding="8dp"/>

                    <!-- Separator -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@color/card_header"/>

                    <!-- TODAY'S DATE DISPLAY -->
                    <TextView
                        android:id="@+id/tvTodayDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:letterSpacing="0.05"
                        android:padding="15dp"
                        android:text="WEDNESDAY, 14 MAY 2026"
                        android:textColor="@color/on_surface_secondary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- === ACTIVE MISSIONS === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_brutalist_container">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/card_header"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ACTIVE_MISSIONS"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/card_header_text"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tvPendingCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3 PENDING"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:background="@color/surface"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:letterSpacing="0.05"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvEmptyToday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="> NO_MISSIONS_FOUND."
                    android:textColor="@color/on_surface_muted"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:paddingVertical="24dp"
                    android:paddingHorizontal="16dp"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTodayTasks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:orientation="vertical"/>
            </LinearLayout>
                
            <!-- FAB: retro square add button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/fabAddTask"
                style="@style/Widget.Planify.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:text="[+] NEW_TASK"
                android:textSize="16sp"/>

            <!-- === TODAY_STATS === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:background="@drawable/bg_brutalist_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/card_header"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="TODAY_STATS"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/card_header_text"
                        android:letterSpacing="0.05"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="COMPLETED"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface"/>
                    <TextView
                        android:id="@+id/tvTodayTaskCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="04"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"/>
                </LinearLayout>
                
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@color/card_header"/>
                    
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="POMODOROS"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface"/>
                    <TextView
                        android:id="@+id/tvPomodoroCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
