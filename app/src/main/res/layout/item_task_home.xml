<?xml version="1.0" encoding="utf-8"?>
<!-- HOME TASK ITEM — Retro 8-bit Brutalist (horizontal list on home screen) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="180dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginEnd="8dp"
    android:background="@drawable/bg_brutalist_card">

    <!-- Inverted header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_header"
        android:padding="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvHomeTaskPriority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="URGENT"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/card_header_text"
            android:letterSpacing="0.1"
            android:textAllCaps="true"/>

    </LinearLayout>

    <!-- Task body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvHomeTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Task Title"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:maxLines="2"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvHomeTaskDue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DUE: TODAY"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface_muted"
            android:letterSpacing="0.05"
            android:textAllCaps="true"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

</LinearLayout>
